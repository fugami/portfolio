# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in values to activate integrations.
# Everything works WITHOUT these (the app falls back to a local JSON store and
# a free handwriting font). Add them when you're ready to go live.
# ---------------------------------------------------------------------------

# Supabase --- when both are present, the data layer reads/writes Supabase
# instead of the local data/store.json file.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key used by admin writes + image uploads (NEVER expose to client).
SUPABASE_SERVICE_ROLE_KEY=

# Adobe Fonts (Typekit) --- the web project ("kit") ID for the "Ernie" face.
# When set, the kit's CSS is loaded and "ernie" becomes the handwriting font.
# Until then a close free fallback (Caveat) is used.
NEXT_PUBLIC_ADOBE_KIT_ID=
